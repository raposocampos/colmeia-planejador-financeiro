{
  "name": "colmeia-planejador-financeiro",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "node scripts/run-vinext.mjs dev",
    "build": "node scripts/run-vinext.mjs build",
    "build:pages": "node scripts/build-pages.mjs",
    "build:review": "node scripts/build-review.mjs",
    "serve:review": "node scripts/serve-static.mjs out",
    "screenshots:v2": "node scripts/capture-v2-screenshots.mjs",
    "screenshots:onboarding": "node scripts/capture-onboarding-tutorial.mjs",
    "start": "node scripts/run-vinext.mjs start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:components": "vitest run tests/components",
    "test:e2e": "playwright test",
    "test:staging:security": "node scripts/test-staging-security.mjs",
    "verify:migrations": "node scripts/verify-supabase-migrations.mjs",
    "staging:validate": "node scripts/validate-staging-config.mjs",
    "check:secrets": "node scripts/check-secrets.mjs",
    "audit:deps": "pnpm audit --audit-level high",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern out --ignore-pattern .next"
  },
  "packageManager": "pnpm@11.7.0",
  "dependencies": {
    "@supabase/supabase-js": "2.110.7",
    "dexie": "^4.4.4",
    "lucide-react": "^1.24.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.81.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.45.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitejs/plugin-rsc": "0.5.27",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "react-server-dom-webpack": "19.2.6",
    "supabase": "2.109.1",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.1.5",
    "vitest": "^4.1.10",
    "wrangler": "4.111.0"
  },
  "type": "module"
}
